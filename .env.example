# Gmail API OAuth2 Credentials
# Dapatkan dari Google Cloud Console → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here

# Gmail address yang menerima forwarded email dari Cloudflare
GMAIL_ADDRESS=yourgmail@gmail.com

# ============================================
# MULTI-DOMAIN CONFIGURATION (Recommended)
# ============================================
# Daftar domain dalam format JSON array
# Setiap domain membutuhkan zone ID Cloudflare-nya masing-masing
# Bisa menambahkan berapapun domain yang diinginkan
#
# Format: [{"domain":"domain1.com","zoneId":"zone_id_1"},{"domain":"domain2.com","zoneId":"zone_id_2"}]
#
EMAIL_DOMAINS=[{"domain":"mail1.com","zoneId":"your_zone_id_1"},{"domain":"mail2.com","zoneId":"your_zone_id_2"}]

# ============================================
# SINGLE DOMAIN FALLBACK (Legacy)
# ============================================
# Jika EMAIL_DOMAINS tidak di-set, akan pakai config di bawah ini
# EMAIL_DOMAIN=yourdomain.com
# CLOUDFLARE_ZONE_ID=your_zone_id_here

# Cloudflare API Credentials
# Dapatkan dari Cloudflare Dashboard → My Profile → API Tokens → Create Token
# Permission yang dibutuhkan: Zone → Email Routing Rules → Edit
# NOTE: API Token harus punya akses ke SEMUA zone/domain yang akan dipakai
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# (Optional) Account ID - ada di Cloudflare Dashboard → Overview (sidebar kanan bawah)
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
