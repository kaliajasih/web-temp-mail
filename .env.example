# ============================================
# SET SEMUA VARIABLE INI DI VERCEL DASHBOARD
# Settings → Environment Variables
# File ini hanya referensi
# ============================================

# Gmail API OAuth2 Credentials
GMAIL_CLIENT_ID=your_client_id_here
GMAIL_CLIENT_SECRET=your_client_secret_here
GMAIL_REFRESH_TOKEN=your_refresh_token_here
GMAIL_ADDRESS=your_gmail@gmail.com

# Cloudflare API Token (1 token untuk semua domain)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Email Domains (tambah sebanyak yang kamu mau)
# Format: EMAIL_DOMAIN_1 + EMAIL_ZONE_1, EMAIL_DOMAIN_2 + EMAIL_ZONE_2, dst.
EMAIL_DOMAIN_1=example1.com
EMAIL_ZONE_1=zone_id_domain_1
EMAIL_DOMAIN_2=example2.com
EMAIL_ZONE_2=zone_id_domain_2
EMAIL_DOMAIN_3=example3.com
EMAIL_ZONE_3=zone_id_domain_3
# ... tambah sampai EMAIL_DOMAIN_20 / EMAIL_ZONE_20

# Google reCAPTCHA v2 Keys
# Dapatkan dari: https://www.google.com/recaptcha/admin
# Pilih tipe: reCAPTCHA v2 "I'm not a robot" Checkbox
RECAPTCHA_SITE_KEY=your_recaptcha_site_key_here
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key_here
